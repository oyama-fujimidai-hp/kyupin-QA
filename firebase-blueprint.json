{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Search": {
      "title": "Search",
      "description": "User search history and results",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "answer": { "type": "string" },
        "sources": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "query", "answer", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public user profiles"
    },
    "/users/{userId}/private/profile": {
      "schema": "User",
      "description": "Private sensitive user data"
    },
    "/users/{userId}/searches/{searchId}": {
      "schema": "Search",
      "description": "User search history"
    }
  }
}
